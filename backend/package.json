{
	"name": "rooms-management-backend",
	"version": "1.0.0",
	"main": "dist/app.js",
	"scripts": {
		"start": "node dist/app.js",
		"dev": "nodemon --watch src --ext ts,json --exec ts-node src/app.ts",
		"build": "tsc",
		"typeorm": "typeorm-ts-node-commonjs",
		"migration:generate": "npm run typeorm -- migration:generate src/migration/Migration -d src/db/data-source.ts",
		"migration:create": "npm run typeorm -- migration:create src/migration/Migration",
		"migration:run": "npm run typeorm -- migration:run -d src/db/data-source.ts",
		"migration:revert": "npm run typeorm -- migration:revert -d src/db/data-source.ts",
		"migration:show": "npm run typeorm -- migration:show -d src/db/data-source.ts",
		"seed": "ts-node src/seeders/index.ts",
		"test": "jest --runInBand",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage --runInBand"
	},
	"dependencies": {
		"bcrypt": "^6.0.0",
		"bcryptjs": "^3.0.3",
		"cors": "^2.8.6",
		"dotenv": "^16.4.5",
		"express": "^5.2.1",
		"jsonwebtoken": "^9.0.3",
		"pg": "^8.13.1",
		"reflect-metadata": "^0.2.2",
		"ts-node": "^10.9.2",
		"typeorm": "^0.3.30",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jest": "^29.5.12",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.11.10",
		"@types/supertest": "^6.0.2",
		"better-sqlite3": "^11.5.0",
		"jest": "^29.7.0",
		"nodemon": "^3.1.14",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"typescript": "^6.0.3"
	}
}
